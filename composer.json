{
    "name": "alfredpay/service-virtualization",
    "description": "AlfredPay Service Virtualization Platform — Stateful API simulators with callback orchestration",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "symfony/dotenv": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "install-db": "php bin/install-schema.php",
        "fire-callbacks": "php bin/fire-callbacks.php"
    },
    "config": {
        "sort-packages": true
    }
}
