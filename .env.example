# AlfredPay Service Virtualization Platform
# Copy to .env and fill in your values

# Database (MySQL on TigerTech shared hosting)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# App
APP_ENV=production
APP_DEBUG=false
APP_SECRET=change-this-to-a-random-string

# Base URL where this app is deployed (used for self-referencing URLs and verification links)
# Subdomain approach (recommended):
APP_BASE_URL=https://virtual-services.intelycs.com
# Path-based fallback (if subdomains don't work):
# APP_BASE_URL=https://intelycs.com/service-virtualization/public

# Logging
LOG_LEVEL=info
